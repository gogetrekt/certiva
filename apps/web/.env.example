# ──────────────────────────────────────────────────────────────────────────────
# Certiva Web (Next.js) — Environment Configuration Example
# Copy to apps/web/.env and fill in real values.
# NEVER commit apps/web/.env to source control.
#
# This file contains only Next.js / BFF (route handler) config.
# JWT_SECRET, DATABASE_URL, REDIS_URL, and PRIVATE_KEY do NOT belong here.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime mode ──────────────────────────────────────────────────────────────
# NODE_ENV: Next.js build and runtime mode (always production for pnpm start)
# APP_ENV:  deployment context (development | staging | production)
NODE_ENV=production
APP_ENV=staging

# ── Internal API URL ──────────────────────────────────────────────────────────
# Server-side only. Used by BFF route handlers to reach the NestJS API.
# This value is NEVER sent to the browser.
# Same machine: http://127.0.0.1:4000/api
# Separate server: http://<internal-host>:4000/api
INTERNAL_API_URL=http://127.0.0.1:4000/api

# ── Cookie security ───────────────────────────────────────────────────────────
# Set to true when the browser reaches the app over HTTPS (Cloudflare, reverse
# proxy, or any TLS terminator in front of Next.js).
# Set to false only for local plain-HTTP development.
COOKIE_SECURE=true

# ── Public browser-safe variables (NEXT_PUBLIC_ prefix) ───────────────────────
# These are inlined into the browser bundle at build time.
# Only put values here that are safe to expose publicly.

# Public-facing site URL (used for canonical links, QR codes, og metadata).
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Support contact email displayed on the contact page.
NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.example
