{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prisma:generate": "prisma generate --schema=../../apps/api/prisma/schema.prisma",
    "prebuild": "pnpm prisma:generate || true",
    "build": "tsup src/index.ts --format cjs --dts --sourcemap --clean",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@certiva/contracts": "workspace:*",
    "@certiva/types": "workspace:*",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.25.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@certiva/config": "workspace:*",
    "@types/node": "^20.19.40",
    "prisma": "^6.19.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
