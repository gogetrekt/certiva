# ──────────────────────────────────────────────────────────────────────────────
# Certiva Worker — Environment Configuration Example
# Copy to apps/worker/.env and fill in real values.
# NEVER commit apps/worker/.env to source control.
#
# The worker process reads ONLY the variables listed here.
# Do NOT add CORS_ORIGINS, JWT_SECRET, PORT, or API_BASE_URL — they are
# API/web concerns and the worker ignores them entirely.
# ──────────────────────────────────────────────────────────────────────────────

# ── Redis (required) ──────────────────────────────────────────────────────────
# Used for BullMQ job queues (issuance, retry, credential-anchor).
REDIS_URL=redis://localhost:6379

# ── Database (required) ───────────────────────────────────────────────────────
# Used by Prisma ORM. Must match API DATABASE_URL.
DATABASE_URL=postgresql://user:password@localhost:5432/certiva

# ── Blockchain ────────────────────────────────────────────────────────────────
# Certiva uses blockchain anchoring for credential issuance and revocation.
# Set BLOCKCHAIN_ENABLED=true (default for production) to enable on-chain ops.
# When enabled, all four vars below are required.
# PRIVATE_KEY signs on-chain transactions — store in a secret manager in production.
# Never commit a real private key to source control.
BLOCKCHAIN_ENABLED=true
POLYGON_AMOY_RPC_URL=https://<your-polygon-amoy-rpc-url>
PRIVATE_KEY=0x<64-hex-character-private-key>
CONTRACT_ADDRESS=0x<40-hex-character-contract-address>
ISSUER_WALLET=0x<40-hex-character-issuer-wallet-address>
BLOCKCHAIN_RPC_TIMEOUT_MS=12000
