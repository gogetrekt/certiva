DATABASE_URL=postgresql://certiva:certiva_password@localhost:5432/certiva?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-16-characters
JWT_EXPIRES_IN=12h
PORT=4000
CORS_ORIGIN=http://localhost:3000
API_PUBLIC_BASE_URL=http://127.0.0.1:4000/api
WEB_PUBLIC_BASE_URL=http://127.0.0.1:3000
ASSET_STORAGE_ROOT=storage

RATE_LIMIT_STORE=redis
RATE_LIMIT_REDIS_PREFIX=certiva:rate-limit
RATE_LIMIT_AUTH_LOGIN_MAX=5
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_MAX=30
RATE_LIMIT_VERIFY_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_UPLOAD_MAX=10
RATE_LIMIT_VERIFY_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX=100
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# NODE_ENV=development
# POLYGON_AMOY_RPC_URL=https://<polygon-amoy-rpc-url>
# PRIVATE_KEY=0x<64-hex-character-private-key>
# CONTRACT_ADDRESS=0x<40-hex-character-contract-address>
# ISSUER_WALLET=0x<40-hex-character-issuer-address>
# BLOCKCHAIN_RPC_TIMEOUT_MS=12000
