# ──────────────────────────────────────────────────────────────────────────────
# Certiva API — Environment Configuration Example
# Copy to apps/api/.env and fill in real values.
# NEVER commit apps/api/.env to source control.
#
# This file is the authoritative reference for the API process environment.
# The API loads both this file and the root .env — values here take precedence.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime mode ──────────────────────────────────────────────────────────────
# NODE_ENV: framework build mode — controls NestJS/Express production optimizations
# APP_ENV:  deployment context — staging = exposed but not final prod
NODE_ENV=production
APP_ENV=staging

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Required. Must match Docker postgres credentials in docker-compose.yml.
DATABASE_URL=postgresql://user:password@localhost:5432/certiva?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required. Used for BullMQ job queues and rate limiting.
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
# JWT_SECRET: minimum 64 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Never use a placeholder, dictionary word, or example value in staging/production.
JWT_SECRET=replace_with_random_64_plus_character_secret
JWT_EXPIRES_IN=12h

# ── CORS ──────────────────────────────────────────────────────────────────────
# Required in staging/production. Comma-separated list of allowed origins.
# Wildcard (*) is rejected. Empty value is rejected.
CORS_ORIGINS=https://your-domain.example,http://localhost:3000,http://127.0.0.1:3000

# ── Cookie / proxy ────────────────────────────────────────────────────────────
# COOKIE_SECURE=true when serving over HTTPS (Cloudflare, reverse proxy).
# TRUST_PROXY=true when running behind Cloudflare or a reverse proxy/tunnel.
COOKIE_SECURE=true
TRUST_PROXY=true

# ── Public URLs ───────────────────────────────────────────────────────────────
# Used for QR codes, verification links, and credential metadata URIs.
# Set to your public domain in staging/production.
API_PUBLIC_BASE_URL=https://your-domain.example/api
WEB_PUBLIC_BASE_URL=https://your-domain.example

# ── Asset storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → use local filesystem under ASSET_STORAGE_ROOT
# STORAGE_DRIVER=r2     → use Cloudflare R2 (requires R2_* vars below)
STORAGE_DRIVER=r2
ASSET_STORAGE_ROOT=storage

# ── Cloudflare R2 (required when STORAGE_DRIVER=r2) ───────────────────────────
# R2_ENDPOINT: jurisdiction-specific S3 endpoint for your account.
#   Format: https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL: public/CDN base URL if the bucket has public access enabled.
#   Leave blank if you always serve assets through the API download routes.
# R2_FORCE_PATH_STYLE: set true for R2 (R2 does not use virtual-hosted buckets).
R2_ACCOUNT_ID=replace_with_account_id
R2_BUCKET=certiva
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_ENDPOINT=https://replace_with_account_id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://assets.your-domain.example
R2_FORCE_PATH_STYLE=true

# ── Rate limiting (all optional — defaults shown) ─────────────────────────────
RATE_LIMIT_STORE=redis
RATE_LIMIT_REDIS_PREFIX=certiva:rate-limit
RATE_LIMIT_AUTH_LOGIN_MAX=5
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_MAX=30
RATE_LIMIT_VERIFY_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_UPLOAD_MAX=10
RATE_LIMIT_VERIFY_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX=100
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# ── Blockchain (optional — leave BLOCKCHAIN_ENABLED unset or false to disable) ─
# When BLOCKCHAIN_ENABLED=true, all three vars below become required.
# PRIVATE_KEY must be stored in a secret manager / KMS in production.
# Never commit a real private key to source control.
BLOCKCHAIN_ENABLED=false
# POLYGON_AMOY_RPC_URL=https://<your-polygon-amoy-rpc-url>
# PRIVATE_KEY=0x<64-hex-character-private-key-for-dev-only>
# CONTRACT_ADDRESS=0x<40-hex-character-contract-address>
# ISSUER_WALLET=0x<40-hex-character-issuer-wallet-address>
# BLOCKCHAIN_RPC_TIMEOUT_MS=12000
