# ──────────────────────────────────────────────────
# Certiva — Environment Configuration Example
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://certiva:certiva_password@localhost:5432/certiva?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# Minimum 32 characters. Generate with:
#   openssl rand -base64 48
# Production: use a secret manager / KMS / platform secrets (not .env files).
# Do NOT use any placeholder, dictionary word, or example value in production.
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_48
JWT_EXPIRES_IN=12h

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Public URLs (used for QR codes, verification links, metadata URIs)
API_PUBLIC_BASE_URL=http://127.0.0.1:4000/api
WEB_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Asset storage root (local filesystem path for credential assets)
ASSET_STORAGE_ROOT=storage

# Rate limiting
RATE_LIMIT_STORE=redis
RATE_LIMIT_REDIS_PREFIX=certiva:rate-limit
RATE_LIMIT_AUTH_LOGIN_MAX=5
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_MAX=30
RATE_LIMIT_VERIFY_WINDOW_SECONDS=60
RATE_LIMIT_VERIFY_UPLOAD_MAX=10
RATE_LIMIT_VERIFY_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX=100
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# Environment
# NODE_ENV=production

# ──────────────────────────────────────────────────
# Blockchain (optional — leave unset to disable)
# ──────────────────────────────────────────────────
# Set BLOCKCHAIN_ENABLED=true to enable on-chain anchoring.
# All three blockchain vars are required when enabled.
#
# BLOCKCHAIN_ENABLED=true
# POLYGON_AMOY_RPC_URL=https://<your-polygon-amoy-rpc-url>
#
# PRIVATE_KEY: The issuer wallet private key used to sign transactions.
# WARNING: Store in a secret manager / KMS / platform secrets in production.
# Never commit a real private key to source control.
# PRIVATE_KEY=0x<64-hex-character-private-key-for-dev-only>
#
# CONTRACT_ADDRESS=0x<40-hex-character-contract-address>
# ISSUER_WALLET=0x<40-hex-character-issuer-wallet-address>
# BLOCKCHAIN_RPC_TIMEOUT_MS=12000
