# ──────────────────────────────────────────────────────────────────────────────
# Certiva — Root Environment Configuration Example
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
#
# This root .env is the fallback for all processes in the monorepo.
# Each app also has its own env file that takes precedence for its process:
#   apps/api/.env      — NestJS API runtime config (authoritative for API)
#   apps/web/.env      — Next.js web runtime config (authoritative for web)
#   apps/worker/.env   — Worker process config (authoritative for worker)
#
# Rule of thumb:
#   - Put secrets and service config in the per-app .env that owns them.
#   - Use this root .env only for docker-compose overrides or repo-level scripts.
# ──────────────────────────────────────────────────────────────────────────────

# ── Docker Compose (PostgreSQL) ───────────────────────────────────────────────
# These match the values hardcoded in docker-compose.yml.
# If you change the Docker credentials, update DATABASE_URL in apps/api/.env
# and apps/worker/.env to match.
POSTGRES_USER=certiva
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=certiva

# ── Runtime mode ──────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=staging

# ── Database ──────────────────────────────────────────────────────────────────
# Must match Docker postgres credentials above.
DATABASE_URL=postgresql://user:password@localhost:5432/certiva?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication (API only — do not share with web or worker) ───────────────
# Minimum 64 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_with_random_64_plus_character_secret
JWT_EXPIRES_IN=12h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS (API only) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Wildcard (*) rejected in staging/prod.
CORS_ORIGINS=https://your-domain.example,http://localhost:3000,http://127.0.0.1:3000

# ── Cookie / proxy (API + web) ────────────────────────────────────────────────
COOKIE_SECURE=true
TRUST_PROXY=true

# ── Public URLs (for QR codes, verification links, asset metadata) ────────────
API_PUBLIC_BASE_URL=https://your-domain.example/api
WEB_PUBLIC_BASE_URL=https://your-domain.example

# ── Asset storage (API only) ──────────────────────────────────────────────────
# STORAGE_DRIVER=r2 is required in staging and production.
# STORAGE_DRIVER=local is only permitted in local development (APP_ENV=development).
STORAGE_DRIVER=r2

# ASSET_STORAGE_ROOT is only used when STORAGE_DRIVER=local (local dev only).
# Not required or used when STORAGE_DRIVER=r2.
# ASSET_STORAGE_ROOT=storage

# Cloudflare R2 — required when STORAGE_DRIVER=r2 (API only — never expose to browser)
R2_ACCOUNT_ID=replace_with_account_id
R2_BUCKET=certiva-assets
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://assets.your-domain.example
R2_FORCE_PATH_STYLE=true

# ── Blockchain (optional — leave BLOCKCHAIN_ENABLED unset or false to disable) ─
BLOCKCHAIN_ENABLED=false
# POLYGON_AMOY_RPC_URL=https://<your-polygon-amoy-rpc-url>
# PRIVATE_KEY=0x<64-hex-character-private-key-for-dev-only>
# CONTRACT_ADDRESS=0x<40-hex-character-contract-address>
# ISSUER_WALLET=0x<40-hex-character-issuer-wallet-address>
# BLOCKCHAIN_RPC_TIMEOUT_MS=12000

# ── Rate limiting (API only, all optional — defaults shown) ───────────────────
# RATE_LIMIT_STORE=redis
# RATE_LIMIT_REDIS_PREFIX=certiva:rate-limit
# RATE_LIMIT_AUTH_LOGIN_MAX=5
# RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
# RATE_LIMIT_VERIFY_MAX=30
# RATE_LIMIT_VERIFY_WINDOW_SECONDS=60
# RATE_LIMIT_VERIFY_UPLOAD_MAX=10
# RATE_LIMIT_VERIFY_UPLOAD_WINDOW_SECONDS=60
# RATE_LIMIT_ADMIN_MAX=100
# RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
