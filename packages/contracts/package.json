{
  "name": "@certiva/contracts",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  },
  "devDependencies": {
    "@certiva/config": "workspace:*",
    "@nomicfoundation/hardhat-ethers": "^4.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.17",
    "@types/node": "^20.19.40",
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0",
    "hardhat": "^3.0.14",
    "ts-node": "^10.9.2",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  }
}
